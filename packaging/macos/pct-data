#!/bin/sh
set -eu

DATA_DIR="${PCT_DATA_DIR:-$HOME/Library/Application Support/Personal Chess Tutor}"
usage() {
  printf '%s\n' "usage: pct-data location | backup ARCHIVE | restore ARCHIVE | reset | uninstall"
}

case "${1:-}" in
  location)
    printf '%s\n' "$DATA_DIR"
    ;;
  backup)
    [ "$#" -eq 2 ] || { usage; exit 2; }
    mkdir -p "$(dirname "$2")"
    tar -czf "$2" -C "$(dirname "$DATA_DIR")" "$(basename "$DATA_DIR")"
    ;;
  restore)
    [ "$#" -eq 2 ] || { usage; exit 2; }
    [ -f "$2" ] || { printf '%s\n' "backup does not exist: $2" >&2; exit 1; }
    mkdir -p "$(dirname "$DATA_DIR")"
    if [ -e "$DATA_DIR" ]; then
      mv "$DATA_DIR" "$DATA_DIR.before-restore-$(date +%Y%m%d%H%M%S)"
    fi
    tar -xzf "$2" -C "$(dirname "$DATA_DIR")"
    ;;
  reset)
    printf '%s' "Delete all tutor data at $DATA_DIR? Type DELETE: "
    read -r confirmation
    [ "$confirmation" = DELETE ] || { printf '%s\n' "Reset cancelled."; exit 1; }
    rm -rf "$DATA_DIR"
    ;;
  uninstall)
    printf '%s\n' "Remove the application from /Applications and run 'pct-data reset' to delete local data."
    ;;
  *) usage; exit 2 ;;
esac
